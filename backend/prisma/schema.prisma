generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Χιονοδρομικό Κέντρο
model Resort {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schools   School[]
}

// Σχολή Σκι
model School {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resortId    String
  resort      Resort       @relation(fields: [resortId], references: [id])
  instructors Instructor[]
  lessons     Lesson[]
}

// Εκπαιδευτής
model Instructor {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  specialty String[] // ["ski", "snowboard"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

// Μάθημα
model Lesson {
  id          String   @id @default(uuid())
  date        DateTime
  startTime   String
  duration    Int
  sport       String
  level       String
  price       Float
  type        String   @default("individual") // "individual" | "group" | "open_group"
  persons     Int      @default(1)
  maxPersons  Int      @default(10)
  minPersons  Int      @default(4)
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])
  bookings     Booking[]
}

// Πελάτης
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
}

// Κράτηση
model Booking {
  id            String   @id @default(uuid())
  customerName  String
  customerPhone String
  status        String   @default("confirmed") // "confirmed" | "cancelled"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lessonId      String
  lesson        Lesson    @relation(fields: [lessonId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
}